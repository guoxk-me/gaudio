{
  "name": "@gaudio/docs",
  "type": "module",
  "private": true,
  "scripts": {
    "api": "typedoc",
    "build": "pnpm run api && vitepress build .",
    "dev": "pnpm run api && vitepress dev .",
    "e2e": "playwright test --config ../../playwright.config.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dashjs": "^5.2.0",
    "gaudio": "workspace:*",
    "hls.js": "^1.6.16"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "vue-tsc": "^3.3.5"
  }
}
