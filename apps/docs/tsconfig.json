{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": [
      "node",
      "vite/client"
    ],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    ".vitepress/**/*.ts",
    "examples/**/*.ts",
    "examples/**/*.vue",
    "*.test.ts"
  ],
  "exclude": [
    ".vitepress/dist"
  ]
}
