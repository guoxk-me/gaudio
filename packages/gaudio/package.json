{
  "name": "gaudio",
  "type": "module",
  "version": "0.4.0",
  "description": "A browser-first TypeScript audio streaming library.",
  "author": "guoxk",
  "license": "MIT",
  "homepage": "https://github.com/guoxk/gaudio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guoxk/gaudio.git"
  },
  "bugs": {
    "url": "https://github.com/guoxk/gaudio/issues"
  },
  "keywords": [
    "audio",
    "streaming",
    "hls",
    "dash",
    "browser",
    "media",
    "player",
    "typescript"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hls": {
      "import": {
        "types": "./dist/hls.d.ts",
        "default": "./dist/hls.js"
      },
      "require": {
        "types": "./dist/hls.d.cts",
        "default": "./dist/hls.cjs"
      }
    },
    "./dash": {
      "import": {
        "types": "./dist/dash.d.ts",
        "default": "./dist/dash.js"
      },
      "require": {
        "types": "./dist/dash.d.cts",
        "default": "./dist/dash.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "hls": [
        "./dist/hls.d.ts"
      ],
      "dash": [
        "./dist/dash.d.ts"
      ]
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "pnpm run typecheck && pnpm run test && pnpm run build && pnpm run pack:dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "dashjs": "^5.2.0",
    "hls.js": "^1.6.16"
  },
  "peerDependenciesMeta": {
    "dashjs": {
      "optional": true
    },
    "hls.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.4",
    "@types/node": "^26.0.1",
    "dashjs": "^5.2.0",
    "hls.js": "^1.6.16",
    "publint": "^0.3.21",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
