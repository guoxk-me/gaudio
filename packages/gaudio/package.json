{
  "name": "gaudio",
  "type": "module",
  "version": "0.4.0",
  "description": "A browser-first TypeScript audio streaming library.",
  "author": "guoxk",
  "license": "MIT",
  "homepage": "https://github.com/guoxk/gaudio#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guoxk/gaudio.git"
  },
  "bugs": {
    "url": "https://github.com/guoxk/gaudio/issues"
  },
  "keywords": [
    "audio",
    "streaming",
    "hls",
    "dash",
    "browser",
    "media",
    "player",
    "typescript"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./hls": {
      "types": "./dist/hls.d.ts",
      "import": "./dist/hls.js",
      "require": "./dist/hls.cjs"
    },
    "./dash": {
      "types": "./dist/dash.d.ts",
      "import": "./dist/dash.js",
      "require": "./dist/dash.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "dashjs": "^5.2.0",
    "hls.js": "^1.6.16"
  },
  "peerDependenciesMeta": {
    "dashjs": {
      "optional": true
    },
    "hls.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "dashjs": "^5.2.0",
    "hls.js": "^1.6.16",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
