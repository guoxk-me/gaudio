{
  "name": "gaudio-workspace",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "docs:build": "turbo run build --filter=@gaudio/docs",
    "docs:dev": "turbo run dev --filter=@gaudio/docs...",
    "e2e": "turbo run e2e --filter=@gaudio/docs",
    "lint": "pnpm run lint:workspace && eslint eslint.config.mjs",
    "lint:workspace": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "turbo": "^2.10.0"
  }
}
