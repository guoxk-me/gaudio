{
  "name": "gaudio-workspace",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "docs:build": "turbo run build --filter=@gaudio/docs",
    "docs:dev": "turbo run dev --filter=@gaudio/docs...",
    "lint": "pnpm run lint:workspace && eslint eslint.config.mjs",
    "lint:workspace": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "eslint": "^10.4.1",
    "turbo": "^2.9.18"
  }
}
