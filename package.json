{
  "name": "gaudio",
  "type": "module",
  "version": "0.3.0",
  "description": "A browser-first TypeScript audio streaming library.",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "pnpm run typecheck:library && pnpm run typecheck:demo",
    "typecheck:demo": "vue-tsc --noEmit -p demo/tsconfig.json",
    "typecheck:library": "tsc --noEmit"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.1",
    "hls.js": "^1.6.16",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.37",
    "vue-tsc": "3.2.9"
  }
}
